{    "collection_rules": {      "type_must_be": "FeatureCollection",      "features_key_required": true    },    "feature_rules": {      "feature_type_must_be": "Feature",      "geometry_required": true,      "properties_required": true    },    "geometry_rules": {      "geometry_type_must_be": "Polygon",      "coordinates_required": true,      "coordinates_min_length": 4    },    "property_rules": {      "resolution_required": true,      "resolution_type": "int",      "resolution_must_equal": 8,      "index_required": true,      "index_type": "str"    }}