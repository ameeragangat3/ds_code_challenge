# ================================# Python# ================================__pycache__/src/__pychache__/*.py[cod]*$py.class# Compiled extensions*.so# Distribution / packagingbuild/dist/*.egg-info/.eggs/# Logs*.log# Coverage / test.coverage.coverage.*htmlcov/.pytest_cache/.mypy_cache/.cache/# ================================# Virtual Environments# ================================.env.env.*.venv/venv/ENV/env/env.bak/venv.bak/# Conda environmentsconda-meta/*.conda*.env# ================================# IDEs / Editors# ================================# VSCode.vscode/# PyCharm.idea/# Spyder.spyderproject.spyproject/# Jupyter.ipynb_checkpoints/# ================================# OS Files# ================================.DS_StoreThumbs.db# ================================# Secrets / Credentials# ================================*.pem*.key*.crt*.aws.aws/credentials.jsoncreds.jsonds_code_challenge_creds.json# ================================# Data Files (if large or generated)# ================================data/src/data/data/*.csvdata/*.gzdata/*.geojsondata/*.odsdata/*.parquet# Allow small schema/config files!data/*.json# ================================# Output / Generated Files# ================================output/reports/*.html*.pdf# Manual review exportsmanual_review.csv# ================================# Temporary Files# ================================*.tmp*.temp*.swp# ================================# Mac / Linux temp# ================================.Trashes